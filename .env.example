DATABASE_URL="file:./dev.db"

# ID мини-приложения ВК (vk.com/apps?act=manage)
NEXT_PUBLIC_VK_APP_ID="1234567"

# Полный Redirect URI для OAuth ВК (должен посимвольно совпадать с настройками ВК)
# Например: http://localhost:3000/ или https://your-domain.com/
NEXT_PUBLIC_VK_REDIRECT_URI="http://localhost:3000/"

# Базовый путь, если приложение развёрнуто не в корне домена (для VK Hosting обычно пусто)
# NEXT_PUBLIC_BASE_PATH="/rps"

# ID группы ВК для бонуса за подписку (опционально)
# NEXT_PUBLIC_VK_GROUP_ID="123456789"

# Секретные ключи приложения ВК для серверной подписи платежей
# Хранить только на сервере, никогда не на клиенте.
VK_APP_SECRET_KEY="ЗАМЕНИ_НА_СЕКРЕТ_ИЗ_НАСТРОЕК_ВК"
VK_SERVICE_KEY="ЗАМЕНИ_НА_SERVICE_KEY_ЕСЛИ_НУЖЕН"

# Включить полноценный серверный режим (API-роуты Next.js, без статического экспорта)
# При деплое на свой сервер установи: NEXT_OUTPUT_EXPORT=0
NEXT_OUTPUT_EXPORT="0"

